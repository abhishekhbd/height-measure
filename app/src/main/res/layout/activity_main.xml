<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/containerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Camera Preview -->
    <TextureView
        android:id="@+id/textureView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Dark gradient overlay at top -->
    <View
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="@drawable/gradient_top" />

    <!-- Dark gradient overlay at bottom -->
    <View
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:layout_gravity="bottom"
        android:background="@drawable/gradient_bottom" />

    <!-- Measurement Overlay -->
    <com.heightmeasure.MeasurementOverlayView
        android:id="@+id/overlayView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Scan Line -->
    <View
        android:id="@+id/scanLine"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="@drawable/scan_line"
        android:visibility="gone" />

    <!-- Pulse Ring (center) -->
    <View
        android:id="@+id/pulseRing"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_gravity="center"
        android:background="@drawable/pulse_ring"
        android:alpha="0.6" />

    <!-- TOP BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingTop="40dp">

        <!-- Title row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="HEIGHT\nMEASURE"
                android:textColor="#00FF88"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:letterSpacing="0.2"
                android:lineSpacingExtra="-4sp" />

            <!-- Unit toggle -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_pill_dark"
                android:paddingStart="12dp"
                android:paddingEnd="8dp">

                <TextView
                    android:id="@+id/tvUnit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="cm"
                    android:textColor="#00FF88"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:paddingEnd="4dp" />

                <Switch
                    android:id="@+id/switchUnit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="#00FF88"
                    android:trackTint="#1A3D2B" />
            </LinearLayout>
        </LinearLayout>

        <!-- Status bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_status_bar"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginTop="8dp">

            <View
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/dot_green" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Initializing camera..."
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:paddingStart="8dp" />

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:indeterminateTint="#00FF88"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <!-- BOTTOM PANEL -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingBottom="32dp">

        <!-- Instruction text -->
        <TextView
            android:id="@+id/tvInstructions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📏 Point camera at a person standing upright"
            android:textColor="#FFFFFFCC"
            android:textSize="16sp"
            android:textAlignment="center"
            android:background="@drawable/bg_instruction"
            android:padding="12dp"
            android:layout_marginBottom="12dp" />

        <!-- Result Card -->
        <LinearLayout
            android:id="@+id/cardResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_result_card"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvHeightCm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-- cm"
                        android:textColor="#00FF88"
                        android:textSize="44sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/tvHeightFt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-- ft --in"
                        android:textColor="#FF6B35"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:id="@+id/tvResult"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MEASURED"
                        android:textColor="#80FFFFFF"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.15" />

                    <TextView
                        android:id="@+id/tvAccuracy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Accuracy: --%"
                        android:textColor="#00FF88"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Calibration Panel -->
        <LinearLayout
            android:id="@+id/layoutCalibration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_calib_card"
            android:padding="14dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvCalibrationGuide"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Set your known height as reference to improve accuracy"
                android:textColor="#AAFFFFFF"
                android:textSize="13sp"
                android:textAlignment="center"
                android:layout_marginBottom="10dp" />

            <SeekBar
                android:id="@+id/seekBarRef"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:progressTint="#00FF88"
                android:thumbTint="#00FF88"
                android:progressBackgroundTint="#1A3D2B" />

            <TextView
                android:id="@+id/tvRefValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Reference: 170 cm (5'7\")"
                android:textColor="#00FF88"
                android:textSize="13sp"
                android:textAlignment="center"
                android:fontFamily="monospace"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <!-- Buttons Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnCalibrate"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:text="⚙"
                android:textSize="22sp"
                android:textColor="#00FF88"
                android:background="@drawable/btn_secondary"
                android:layout_marginEnd="12dp" />

            <Button
                android:id="@+id/btnMeasure"
                android:layout_width="0dp"
                android:layout_height="62dp"
                android:layout_weight="1"
                android:text="MEASURE HEIGHT"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:background="@drawable/btn_measure" />

            <Button
                android:id="@+id/btnReset"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:text="↺"
                android:textSize="22sp"
                android:textColor="#FF6B35"
                android:background="@drawable/btn_secondary"
                android:layout_marginStart="12dp"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
